@model SSSite.Models.Top10ViewModel
@{
    ViewData["Title"] = "Top 10 Números";
    int maxTotal = Model.Contagens.Any() ? Model.Contagens.Max(c => c.TotalSorteios) : 1;
    if (maxTotal == 0) maxTotal = 1;
}

<div class="container py-5">

    @* NÚMERO DO DIA *@
    @if (Model.Ultimo != null)
    {
        <div class="text-center mb-5">
            <p class="text-uppercase fw-bold mb-1" style="letter-spacing:3px; color:#aaa;">Número do Dia</p>
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:160px; height:160px; background: linear-gradient(135deg, #6a11cb, #2575fc);
                box-shadow: 0 0 40px rgba(106,17,203,0.6);">
                <span style="font-size:72px; font-weight:900; color:white;">@Model.Ultimo.Numero</span>
            </div>
            <p class="text-muted">
                Sorteado em @Model.Ultimo.SorteadoEm.ToLocalTime().ToString("dd/MM/yyyy 'às' HH:mm")
            </p>
        </div>
    }
    else
    {
        <div class="text-center mb-5">
            <p class="text-uppercase fw-bold mb-1" style="letter-spacing:3px; color:#aaa;">Número do Dia</p>
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:160px; height:160px; background: linear-gradient(135deg, #444, #222);
                box-shadow: 0 0 40px rgba(0,0,0,0.4);">
                <span style="font-size:48px; font-weight:900; color:#666;">--</span>
            </div>
            <p class="text-muted">Nenhum sorteio realizado ainda.</p>
        </div>
    }

    @* GRÁFICO DE TORRES *@
    <h5 class="text-center mb-4 fw-bold">📊 Histórico de Sorteios</h5>

    <div class="d-flex align-items-flex-end justify-content-center gap-2" style="height:300px;">
        @foreach (var item in Model.Contagens)
        {
            var pct = (item.TotalSorteios * 100) / maxTotal;
            var isUltimo = Model.Ultimo != null && Model.Ultimo.Numero == item.Numero;
            var cor = isUltimo
                ? "linear-gradient(180deg, #6a11cb, #2575fc)"
                : "linear-gradient(180deg, #444, #333)";
            var shadow = isUltimo ? "box-shadow: 0 0 20px rgba(106,17,203,0.7);" : "";

            <div class="d-flex flex-column align-items-center" style="flex:1; max-width:80px;">
                @* Altura mínima de 4px para zeros ficarem visíveis *@
                <span class="fw-bold mb-1" style="font-size:13px;">@item.TotalSorteios</span>
                <div style="width:100%; height:260px; display:flex; align-items:flex-end;">
                    <div style="width:100%; height:max(@pct, 2)%;
                        background:@cor;
                        border-radius:6px 6px 0 0;
                        min-height:4px;
                        @shadow
                        transition: height 0.5s ease;">
                    </div>
                </div>
                <div class="mt-1 fw-bold" style="font-size:15px; @(isUltimo ? "color:#a78bfa;" : "")">
                    @item.Numero
                </div>
            </div>
        }
    </div>

    <p class="text-center text-muted mt-3" style="font-size:13px;">
        O número destacado em roxo é o último sorteado.
    </p>

</div>