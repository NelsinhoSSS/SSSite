@model List<SSSite.Models.MuralMensagem>
@{
    ViewData["Title"] = "MURAL";
    int total = Model.Count;
    bool cheio = total >= 20;
    string estadoContador = total >= 20 ? "counter-full" : total >= 15 ? "counter-warning" : "";
}

<div class="mural-background">

    <div class="mural-top-bar">
        <button type="button"
                class="btn-criar-msg"
                data-bs-toggle="modal"
                data-bs-target="#modalMural"
                @(cheio ? "disabled" : "")>
            [ NOVA MENSAGEM ]
        </button>

        <div class="msg-counter @estadoContador">
            <span class="counter-number">@total</span>
            <span class="counter-sep">/ 20</span>
            <span class="counter-label">recados</span>
            @if (cheio)
            {
                <span class="counter-alert">[ MURAL CHEIO ]</span>
            }
        </div>
    </div>

    <div class="container-fluid">
        <div class="mural-grid">
            @foreach (var msg in Model)
            {
                <div class="card-postit" style="--accent: @msg.corneon; --glow: @(msg.corneon)44;">
                    <form asp-action="Excluir" method="post">
                        <input type="hidden" name="id" value="@msg.id" />
                        <button type="submit" class="btn-delete" onclick="return confirm('Apagar post-it?')">&times;</button>
                    </form>

                    <p class="postit-conteudo">"@msg.conteudo"</p>

                    <div class="postit-rodape">
                        <span class="postit-autor">— @msg.autor</span>
                        <small class="postit-hora">@msg.data.ToString("HH:mm")</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal nova mensagem -->
<div class="modal fade" id="modalMural" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-mural">
            <form asp-action="Postar" method="post">
                <div class="modal-body p-4">

                    <div class="modal-header-custom">
                        <h5 class="modal-titulo">> NOVO_RECADO</h5>
                        <span id="charCount" class="char-badge">200</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-mural">Sua Mensagem</label>
                        <textarea id="txtConteudo" name="conteudo"
                                  class="input-mural"
                                  rows="5" required maxlength="200"
                                  placeholder="Escreva algo para o futuro..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-mural">Assinatura</label>
                        <input type="text" name="autor"
                               class="input-mural"
                               maxlength="30"
                               placeholder="Anônimo">
                    </div>

                    <button type="submit" class="btn-fixar">[ FIXAR NO QUADRO ]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* ── Layout base ── */
    .mural-background {
        background: url('/img/QuadroPinos.jpg') center / cover fixed;
        min-height: 100vh;
        padding-top: 120px;
        position: relative;
    }

    /* ── Barra superior ── */
    .mural-top-bar {
        position: absolute;
        top: 30px;
        left: 30px;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    /* ── Botão criar ── */
    .btn-criar-msg {
        background: rgba(10, 10, 10, 0.9);
        color: #00ff41;
        border: 2px solid #00ff41;
        padding: 12px 24px;
        font-family: 'Courier New', monospace;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        box-shadow: 0 0 10px rgba(0,255,65,.5), inset 0 0 5px rgba(0,255,65,.3);
        transition: all .3s ease;
    }

    .btn-criar-msg:hover:not(:disabled) {
        background: #00ff41;
        color: #0a0a0a;
        box-shadow: 0 0 20px #00ff41, 0 0 40px #00ff41;
        transform: scale(1.05);
    }

    .btn-criar-msg:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        box-shadow: none;
    }

    /* ── Contador ── */
    .msg-counter {
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(10, 10, 10, 0.9);
        border: 2px solid #00ff41;
        padding: 10px 16px;
        font-family: 'Courier New', monospace;
        font-size: .95rem;
        color: #00ff41;
        box-shadow: 0 0 8px rgba(0,255,65,.3);
        transition: border-color .3s, box-shadow .3s, color .3s;
    }

    .msg-counter.counter-warning {
        border-color: #ffc107;
        color: #ffc107;
        box-shadow: 0 0 8px rgba(255,193,7,.4);
    }

    .msg-counter.counter-full {
        border-color: #ff4d4d;
        color: #ff4d4d;
        box-shadow: 0 0 12px rgba(255,77,77,.5);
        animation: pulseRed 1.5s infinite;
    }

    .counter-number { font-size: 1.2rem; font-weight: bold; }
    .counter-sep    { opacity: .7; }
    .counter-label  { margin-left: 6px; font-size: .75rem; opacity: .6; text-transform: uppercase; letter-spacing: 1px; }
    .counter-alert  { margin-left: 10px; font-size: .75rem; font-weight: bold; letter-spacing: 1px; animation: blink 1s step-end infinite; }

    /* ── Grid de post-its ── */
    .mural-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 35px;
        padding: 20px;
        align-items: start;
    }

    /* ── Card post-it ──
       Usa as custom props --accent e --glow definidas inline,
       eliminando todos os outros style="" espalhados no HTML. */
    .card-postit {
        background: rgba(15, 15, 15, .98);
        padding: 30px 20px 15px;
        border-left: 8px solid var(--accent);
        box-shadow: 5px 10px 20px rgba(0,0,0,.5), 0 0 15px var(--glow);
        position: relative;
        transform: rotate(-1deg);
        transition: transform .3s ease;
    }

    .card-postit:hover { transform: scale(1.03) rotate(0deg); z-index: 5; }

    /* Pino vermelho */
    .card-postit::after {
        content: "";
        position: absolute;
        top: -7px;
        left: 50%;
        width: 14px;
        height: 14px;
        background: #ff4d4d;
        border-radius: 50%;
        box-shadow: 0 2px 4px rgba(0,0,0,.5);
    }

    .postit-conteudo {
        color: #fff;
        font-style: italic;
        font-size: 1.1rem;
        flex-grow: 1;
        margin-bottom: 1rem;
    }

    .postit-rodape {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid rgba(255,255,255,.1);
        padding-top: .5rem;
    }

    .postit-autor { color: var(--accent); font-weight: bold; }
    .postit-hora  { color: #6c757d; font-size: .875rem; }

    /* ── Botão deletar ── */
    .btn-delete {
        position: absolute;
        top: 5px;
        right: 10px;
        background: none;
        border: none;
        color: rgba(255,255,255,.3);
        font-size: 1.2rem;
        cursor: pointer;
        transition: color .2s;
    }

    .btn-delete:hover { color: #ff4d4d; }

    /* ── Modal ── */
    .modal-mural {
        background: #111;
        border: 1px solid #00ff41;
        box-shadow: 0 0 15px rgba(0,255,65,.5);
    }

    .modal-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .modal-titulo {
        color: #00ff41;
        font-family: 'Courier New', monospace;
        font-weight: bold;
        letter-spacing: 1px;
        margin: 0;
    }

    .char-badge {
        background: #111;
        color: #00ff41;
        border: 1px solid #00ff41;
        padding: 2px 8px;
        font-size: .85rem;
        font-family: 'Courier New', monospace;
        transition: color .2s, border-color .2s;
    }

    .char-badge.alerta { color: #ff4d4d; border-color: #ff4d4d; }

    .form-label-mural { color: rgba(255,255,255,.5); font-size: .85rem; display: block; margin-bottom: .25rem; }

    .input-mural {
        width: 100%;
        background: #000;
        color: #fff;
        border: 1px solid #6c757d;
        padding: .5rem .75rem;
        font-family: 'Courier New', monospace;
        resize: vertical;
    }

    .input-mural:focus { outline: none; border-color: #00ff41; box-shadow: 0 0 6px rgba(0,255,65,.3); }

    .btn-fixar {
        width: 100%;
        background: #00ff41;
        color: #0a0a0a;
        border: none;
        padding: .6rem;
        font-family: 'Courier New', monospace;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: opacity .2s;
    }

    .btn-fixar:hover { opacity: .85; }

    /* ── Animações ── */
    @@keyframes blink    { 50% { opacity: 0; } }
    @@keyframes pulseRed { 0%, 100% { box-shadow: 0 0 8px rgba(255,77,77,.4); } 50% { box-shadow: 0 0 20px rgba(255,77,77,.8); } }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const textarea  = document.getElementById('txtConteudo');
            const badge     = document.getElementById('charCount');
            const MAX       = 200;

            textarea.addEventListener('input', () => {
                const restante = MAX - textarea.value.length;
                badge.textContent = restante;
                badge.classList.toggle('alerta', restante <= 20);
            });
        });
    </script>
}