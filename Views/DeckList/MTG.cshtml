@model SSSite.Models.MtgViewModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Decklists MTG";
    bool eAdmin = Context.Session.GetString("ModoAdm") == "Ativo";
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0">🃏 Decklists — Commander</h2>
        @if (eAdmin)
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCriarDeck">
                Criar Deck
            </button>
        }
    </div>

    @if (!Model.Decks.Any())
    {
        <p class="text-muted">Nenhum deck criado ainda. Clique em "Criar Deck" para começar!</p>
    }

    @* UM ACCORDION POR DECK *@
    <div class="accordion" id="accordionDecks">
        @foreach (var deck in Model.Decks)
        {
            var totalCartas = deck.Cartas.Sum(c => c.Quantidade);
            var deckIdStr = $"deck-{deck.Id}";

            <div class="accordion-item bg-dark text-white border-secondary mb-2">
                <div class="accordion-header d-flex align-items-center px-3 py-2 gap-2">
                    <button class="accordion-button collapsed bg-dark text-white flex-grow-1"
                            type="button" data-bs-toggle="collapse"
                            data-bs-target="#@deckIdStr">
                        <span class="fw-bold">@deck.Nome</span>
                        @if (!string.IsNullOrEmpty(deck.Comandante))
                        {
                            <small class="text-muted ms-2">— @deck.Comandante</small>
                        }
                        <span class="badge ms-3 @(totalCartas == 100 ? "bg-success" : "bg-warning text-dark")">
                            @totalCartas / 100
                        </span>
                    </button>

                    <div class="d-flex gap-2 ms-2">
                        <button class="btn btn-outline-light btn-sm" onclick="copiarLista('@deck.Id')">📋 Copiar</button>
                        @if (eAdmin)
                        {
                            <button class="btn btn-outline-warning btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#modalEditar-@deck.Id">
                                ✏️ Editar
                            </button>
                            <form asp-action="ExcluirDeck" method="post" class="d-inline"
                                  onsubmit="return confirm('Excluir o deck @deck.Nome?')">
                                <input type="hidden" name="deckId" value="@deck.Id" />
                                <button class="btn btn-outline-danger btn-sm">🗑️ Excluir</button>
                            </form>
                        }
                    </div>
                </div>

                <div id="@deckIdStr" class="accordion-collapse collapse">
                    <div class="accordion-body" style="max-height:400px; overflow-y:auto;">
                        <ul class="list-unstyled mb-0" id="lista-@deck.Id">
                            @foreach (var carta in deck.Cartas)
                            {
                                var scryfallUrl = $"https://scryfall.com/search?q=!\"{Uri.EscapeDataString(carta.Nome)}\"";
                                var imgUrl = $"https://api.scryfall.com/cards/named?exact={Uri.EscapeDataString(carta.Nome)}&format=image&version=small";
                                <li style="font-size:14px;">
                                    <span class="text-muted">@carta.Quantidade×</span>
                                    <a href="@scryfallUrl" target="_blank"
                                       class="card-link text-white"
                                       data-img="@imgUrl">@carta.Nome</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            @* MODAL EDITAR POR DECK *@
            <div class="modal fade" id="modalEditar-@deck.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content bg-dark text-white">
                        <form asp-action="SalvarCartas" method="post">
                            <input type="hidden" name="deckId" value="@deck.Id" />
                            <div class="modal-header border-secondary">
                                <h5 class="modal-title">Editar — @deck.Nome</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <textarea name="listaTexto" class="form-control bg-dark text-white border-secondary"
                                          rows="15" style="font-family:monospace;">@deck.Lista</textarea>
                            </div>
                            <div class="modal-footer border-secondary">
                                <button type="submit" class="btn btn-success w-100">💾 Salvar Lista</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* MODAL CRIAR DECK *@
<div class="modal fade" id="modalCriarDeck" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark text-white">
            <form asp-action="CriarDeckComLista" method="post">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Criar Deck</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome do Deck</label>
                        <input type="text" name="nome" class="form-control bg-dark text-white border-secondary" required maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Comandante</label>
                        <input type="text" name="comandante" class="form-control bg-dark text-white border-secondary" maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lista de Cartas</label>
                        <textarea name="listaTexto" class="form-control bg-dark text-white border-secondary" rows="12" style="font-family:monospace;"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="submit" class="btn btn-primary w-100">✅ Criar e Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tooltip de imagem
        const tooltip = document.createElement('div');
        tooltip.style.cssText = 'position:fixed;z-index:9999;pointer-events:none;display:none;border-radius:8px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.8);';
        const tooltipImg = document.createElement('img');
        tooltipImg.style.cssText = 'width:250px;display:block;';
        tooltip.appendChild(tooltipImg);
        document.body.appendChild(tooltip);

        document.querySelectorAll('.card-link').forEach(link => {
            link.addEventListener('mouseenter', e => {
                tooltipImg.src = link.dataset.img;
                tooltip.style.display = 'block';
            });
            link.addEventListener('mousemove', e => {
                tooltip.style.left = (e.clientX + 15) + 'px';
                tooltip.style.top = (e.clientY - 80) + 'px';
            });
            link.addEventListener('mouseleave', () => {
                tooltip.style.display = 'none';
                tooltipImg.src = '';
            });
        });

        function copiarLista(deckId) {
            const linhas = [];
            document.querySelectorAll('#lista-' + deckId + ' li').forEach(li => {
                linhas.push(li.innerText.replace('×', '').replace(/\s+/, ' ').trim());
            });
            navigator.clipboard.writeText(linhas.join('\n'));
            alert('Lista copiada!');
        }
    </script>
}